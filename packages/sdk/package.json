{
  "name": "@agentlink/sdk",
  "version": "0.1.0",
  "description": "AgentLink SDK for interacting with the AgentLink protocol",
  "license": "MIT",
  "author": "AgentLink Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentlink/agentlink-mvp.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "import": "./dist/actions/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@agentlink/shared": "workspace:*",
    "abitype": "^1.0.0",
    "viem": "catalog:",
    "wagmi": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "typescript": "^5.0.0",
    "viem": "^2.0.0",
    "wagmi": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
