{
  "name": "@agentlink/cli",
  "version": "0.1.0",
  "description": "AgentLink CLI - Developer tooling for autonomous agents",
  "keywords": [
    "agent",
    "cli",
    "a2a",
    "x402",
    "autonomous",
    "developer-tools"
  ],
  "homepage": "https://agentlink.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentlink/agentlink-mvp.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "AgentLink Team",
  "type": "module",
  "bin": {
    "agentlink": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentlink/core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "ora": "^8.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
