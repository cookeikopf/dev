# ============================================
# AgentLink MVP - Environment Configuration
# ============================================

# ============================================
# Application Settings
# ============================================
NEXT_PUBLIC_APP_NAME=AgentLink
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# Supabase Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_ID=your-project-id

# ============================================
# Authentication Provider
# Options: supabase | clerk | nextauth
# ============================================
AUTH_PROVIDER=supabase

# ============================================
# Clerk Authentication (if using Clerk)
# ============================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ============================================
# NextAuth Configuration (if using NextAuth)
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# Webhook Provider Secrets
# ============================================
STRIPE_WEBHOOK_SECRET=whsec_...
ALCHEMY_WEBHOOK_SECRET=...
CIRCLE_WEBHOOK_SECRET=...
COINBASE_WEBHOOK_SECRET=...

# ============================================
# CORS Configuration
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://agentlink.io

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_WINDOW_MS=60000
RATE_LIMIT_DEFAULT_MAX_REQUESTS=60

# ============================================
# Security
# ============================================
API_KEY_ENCRYPTION_KEY=your-encryption-key-min-32-chars-long!!
WEBHOOK_SECRET_MIN_LENGTH=16

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_REQUESTS=true
