{
  "name": "agentlink-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "AgentLink MVP - Decentralized Agent Protocol",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:dashboard": "turbo run dev --filter=dashboard",
    "dev:contracts": "cd contracts && anvil & sleep 2 && forge script script/Deploy.s.sol --broadcast --rpc-url http://localhost:8545",
    "test": "turbo run test",
    "test:contracts": "cd contracts && forge test",
    "test:e2e": "cd apps/dashboard && playwright test",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,sol}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,sol}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=@agentlink/* && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "prettier": "^3.2.5",
    "prettier-plugin-solidity": "^1.3.1",
    "turbo": "^1.13.0"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
