{
  "name": "@agentlink/cli",
  "version": "0.1.0",
  "description": "CLI tool for creating, managing, and deploying AgentLink agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentlink": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agentlink",
    "agent",
    "a2a",
    "cli",
    "scaffold",
    "deployment"
  ],
  "author": "AgentLink Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "fs-extra": "^11.2.0",
    "chokidar": "^3.6.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.11.0",
    "hono": "^4.0.0",
    "@hono/node-server": "^1.8.0",
    "zod": "^3.22.0",
    "figlet": "^1.7.0",
    "boxen": "^7.1.0",
    "listr2": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/fs-extra": "^11.0.0",
    "@types/figlet": "^1.5.0",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.3.0",
    "@vitest/ui": "^1.3.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agentlink/agentlink-cli.git"
  },
  "bugs": {
    "url": "https://github.com/agentlink/agentlink-cli/issues"
  },
  "homepage": "https://agentlink.dev"
}
