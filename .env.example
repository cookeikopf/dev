# AgentLink Environment Variables
# Copy this file to .env and fill in the values

# ==========================================
# General
# ==========================================
NODE_ENV=development

# ==========================================
# Blockchain (Base Sepolia)
# ==========================================
# RPC URLs
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Private key for deployments (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Contract addresses (filled after deployment)
AGENT_REGISTRY_ADDRESS=
TASK_MANAGER_ADDRESS=
REPUTATION_SYSTEM_ADDRESS=
AGENT_LINK_ADDRESS=

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key

# ==========================================
# Dashboard (Next.js)
# ==========================================
# App environment
NEXT_PUBLIC_APP_ENV=development

# WalletConnect Project ID (from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_walletconnect_project_id

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Sentry (error tracking)
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_DSN=your_sentry_dsn
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ==========================================
# SDK
# ==========================================
# Default chain ID for SDK
SDK_DEFAULT_CHAIN_ID=84532

# ==========================================
# CI/CD
# ==========================================
# GitHub Actions secrets
# These are set in GitHub repository settings, not in .env
# - NPM_TOKEN
# - VERCEL_TOKEN
# - VERCEL_ORG_ID
# - VERCEL_PROJECT_ID_DASHBOARD
# - CODECOV_TOKEN
# - SLACK_WEBHOOK_URL

# ==========================================
# Testing
# ==========================================
# Anvil local node
ANVIL_RPC_URL=http://localhost:8545

# Test private key (Anvil default)
TEST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ==========================================
# Monitoring
# ==========================================
# Datadog
DD_API_KEY=your_datadog_api_key
DD_APP_KEY=your_datadog_app_key
